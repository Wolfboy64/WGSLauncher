<Window x:Class="WorkLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkLauncher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Background="Gray" MinWidth="800" MaxWidth="800" MinHeight="450" MaxHeight="450">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel x:Name="LoginPage" Grid.Row="1" Grid.Column="1" Grid.RowSpan="1" Background="DarkMagenta">
            <Grid Height="143">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button x:Name="ConnectButton" 
                Content="Csatlakozás" Width="213" 
                Click="Connect_Click" 
                Style="{StaticResource ModernBottomBorderStyle}" FontSize="20" Margin="27,0,27,0" Grid.Row="1"/>
                <Label Content="WorkLauncher v1.2" FontSize="30" HorizontalAlignment="Center" Foreground="White"  VerticalAlignment="Center" Grid.Row="2"/>
            </Grid>
                

        </StackPanel>
        <!--<DataGrid x:Name="datagridACCs" d:ItemsSource="{d:SampleData ItemCount=0}"/>-->
    </Grid>
</Window>
